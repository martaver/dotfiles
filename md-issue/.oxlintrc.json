{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn"],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "warn",
    "style": "off"
  },
  "rules": {
    "no-console": "off",
    "no-await-in-loop": "off",
    "typescript/no-explicit-any": "error"
  },
  "ignorePatterns": ["dist/**", "node_modules/**", "root/**"]
}

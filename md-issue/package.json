{
  "name": "md-issue",
  "version": "0.0.0",
  "description": "Two-way sync between a directory of markdown files and an issue tracker.",
  "type": "module",
  "module": "src/cli.ts",
  "bin": {
    "md-issue": "./dist/md-issue"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build --compile --minify --target=bun --outfile=dist/md-issue src/cli.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "@sinclair/typebox": "^0.32.0",
    "commander": "^12.0.0",
    "picomatch": "^4.0.0",
    "smol-toml": "^1.3.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/picomatch": "^4.0.0",
    "oxlint": "^1.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
